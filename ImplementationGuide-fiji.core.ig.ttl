       ] ;
       fhir:name [ fhir:v "Fiji Patient" ] ;
       fhir:description [ fhir:v "Core Patient profile for Fiji.\n\nFrom Pacific Patient this profile inherits:\n- PacificHumanName\n- Patient-level clan affiliation\n- Guidance for usual vs official name use" ] ;
